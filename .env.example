# ========================================
# Variáveis de Ambiente — LSTM API
# ========================================
#
# Copie este arquivo para .env e configure
# os valores para seu ambiente local.
#
# Para produção, configure essas variáveis
# nas settings do Render.com
#
# ========================================

# ========== APP BÁSICO ==========

# Nome da aplicação
APP_APP_NAME=Previsão de Preços de Ações — LSTM

# Origins permitidas para CORS (separadas por vírgula ou lista JSON)
# Desenvolvimento: aceita qualquer origem
# Produção: configure apenas domínios confiáveis
APP_CORS_ORIGINS=["*"]

# ========== MODELO & SCALER ==========

# Caminho para o modelo LSTM treinado (relativo ao repo root)
# Padrão: artifacts/modelo_lstm.keras
APP_MODEL_PATH=artifacts/modelo_lstm.keras

# Caminho para o scaler (StandardScaler persistido)
# Padrão: artifacts/scaler.pkl
APP_SCALER_PATH=artifacts/scaler.pkl

# ========== DATABASE ==========

# Caminho para o banco SQLite de logs
# Padrão: data/database.db
# Será criado automaticamente se não existir
APP_DB_PATH=data/database.db

# ========== MODELO LSTM ==========

# Janela de lookback (dias históricos para predição)
# CRÍTICO: Deve bater com o pipeline de treinamento (30 dias)
# Alterar sem retreinar invalida previsões!
APP_LOOK_BACK=30

# Colunas de features (OHLCV)
# Padrão: Close, High, Low, Open, Volume
APP_FEATURE_COLS=["Close", "High", "Low", "Open", "Volume"]

# ========== SERVER ==========

# Porta do servidor (Render.com passa via variável PORT)
# Local: 8000 (padrão)
# Produção: definida pelo Render (PORT=...)
PORT=8000

# Host para bind
# Desenvolvimento: localhost ou 127.0.0.1
# Produção: 0.0.0.0
HOST=0.0.0.0

# ========== LOGGING ==========

# Nível de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ========== RATE LIMITING ==========

# Máximo de requisições por IP na janela de tempo
# Padrão: 100 (para suportar frontend complexo com múltiplos usuários)
# Desenvolvimento: pode aumentar para testes
APP_RATE_LIMIT_MAX_REQUESTS=100

# Tamanho da janela em segundos (5 minutos = 300 seg)
# Padrão: 300 segundos (recomendado)
# Mudar afeta quando contador reseta
APP_RATE_LIMIT_WINDOW_SECONDS=300

# ========== DEBUG ==========

# Modo debug (True/False)
# NUNCA ativar em produção!
DEBUG=False
